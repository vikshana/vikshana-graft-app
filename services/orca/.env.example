# ============================================================
# Orca Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://orca:orca@localhost:5432/orca

# --- Anthropic ---
# Required: Claude Haiku + Sonnet for the agent
ANTHROPIC_API_KEY=sk-ant-...

# --- LangSmith (optional but recommended for debugging) ---
# Get a free key at https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls-...
LANGCHAIN_PROJECT=orca-dev

# --- Slack (optional) ---
# Incoming webhook URL for RCA completion notifications
# Create one at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Grafana MCP ---
# URL of your Grafana instance
# For local development: http://localhost:3002
# In demo mode (make up): the backend connects via Docker network as http://grafana:3000
GRAFANA_URL=http://localhost:3002
# Grafana service account token (needs read access to dashboards, metrics, logs)
GRAFANA_API_KEY=glsa_...

# --- Agent Tuning ---
# Maximum number of MCP tool calls in the investigation phase (default: 15)
ORCA_MAX_INVESTIGATION_STEPS=15
# Maximum tokens to spend in the investigation phase (default: 100000)
ORCA_MAX_INVESTIGATION_TOKENS=100000
# Wall-clock timeout for the full agent run in seconds (default: 300 = 5 minutes)
ORCA_AGENT_TIMEOUT_SECONDS=300

# --- Deduplication ---
# Alerts with the same name + labels arriving within this window (minutes) are
# considered duplicates and linked to the existing RCA instead of spawning a new one.
# Active investigations (triggered/investigating) always absorb duplicates regardless of window.
ORCA_DEDUP_WINDOW_MINUTES=30

# --- Frontend ---
# URL of the Orca frontend (used to generate Slack notification links)
FRONTEND_URL=http://localhost:3000
# URL of the Orca backend (consumed by Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000

